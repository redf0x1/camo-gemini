# CamoFox Connection
# CAMOFOX_URL=http://localhost:9377
# CAMOFOX_HOST=localhost
# CAMOFOX_PORT=9377
# CAMOFOX_API_KEY=

# CamoGemini Identity
# CAMOGEMINI_USER_ID=camo-gemini
# CAMOGEMINI_LOG_LEVEL=INFO

# Request Timeout (milliseconds, default: 30000)
# CAMOGEMINI_REQUEST_TIMEOUT=30000

# Auto-Delete Chat (default: true)
# CAMOGEMINI_AUTO_DELETE_CHAT=true

# Dashboard (default: disabled)
# CAMOGEMINI_DASHBOARD=false
# CAMOGEMINI_DASHBOARD_ENABLED=false
# CAMOGEMINI_DASHBOARD_PORT=9378
